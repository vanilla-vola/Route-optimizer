# Copy to .env and fill in values
MAPBOX_ACCESS_TOKEN=your_mapbox_token_here
# Default mode when clients omit `mode` (clients can override per request)
MATRIX_PROFILE=driving-traffic
USE_HAVERSINE=true
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
MAX_STOPS=25
SOLVER_TIME_LIMIT_S=5
USE_DCIR=true
DCIR_TIME_LIMIT_S=12
DCIR_ROBUST_LAMBDA=0.3
# Mapbox depart_at matrices at local hours (off-peak / midday / peak)
DCIR_MAPBOX_PROFILES=true
DCIR_TIMEZONE=Asia/Kolkata
DCIR_DEPART_HOURS=8,13,18
# Per-leg Directions refresh during DCIR (extra API calls)
DCIR_REFRESH_LEGS=false
PORT=8000
