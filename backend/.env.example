# Copy to .env and fill in values
MAPBOX_ACCESS_TOKEN=your_mapbox_token_here
# Default mode when clients omit `mode` (clients can override per request)
MATRIX_PROFILE=driving
USE_HAVERSINE=true
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
MAX_STOPS=25
SOLVER_TIME_LIMIT_S=5
USE_DCIR=true
DCIR_TIME_LIMIT_S=12
DCIR_ROBUST_LAMBDA=0.3
PORT=8000
